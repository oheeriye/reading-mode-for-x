{
  "manifest_version": 3,
  "name": "X Focus Mode",
  "version": "1.0",
  "description": "Hides sidebars on X.com articles, keeping only the main content.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
